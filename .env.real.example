# =============================================================================
# 真实环境示例：复制为 `.env.real` 后填写密钥（不要提交 `.env.real`）
# 由 `app/config.py` 加载；顺序为 `.env` 后 `.env.real`（后者覆盖同名项）
# =============================================================================

# ----- 应用 / 模型 / Milvus（可与根目录 `.env` 重复，此处覆盖） -----
APP_NAME=Lab Agent
DEBUG=True
HOST=0.0.0.0
PORT=9900

DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_TIMEOUT=10000

RAG_TOP_K=3
RAG_MODEL=qwen-max

# Tavily 公网检索（可选；不设 TAVILY_API_KEY 则不向 Agent 暴露该工具）
# TAVILY_API_KEY=
# TAVILY_MAX_RESULTS=5
# TAVILY_TIMEOUT_SECONDS=25

CHUNK_MAX_SIZE=800
CHUNK_OVERLAP=100

# =============================================================================
# MCP：二选一
#   A) streamable-http + URL（与当前 mcp_servers/* 默认 __main__ 一致）
#   B) stdio + 下方 MCP_*_STDIO_*（由 mcp_servers/cls_stdio.py 等入口启动）
# =============================================================================

# --- 方案 A：HTTP MCP（本仓库默认端口） ---
# MCP_CLS_TRANSPORT=streamable-http
# MCP_CLS_URL=http://127.0.0.1:8003/mcp
# MCP_MONITOR_TRANSPORT=streamable-http
# MCP_MONITOR_URL=http://127.0.0.1:8004/mcp

# --- 方案 B：stdio MCP ---
MCP_CLS_TRANSPORT=stdio
MCP_MONITOR_TRANSPORT=stdio

# 启动 MCP 子进程：建议在项目根用 venv 里的解释器（示例为相对路径，可改为绝对路径）
# MCP_CLS_STDIO_COMMAND=/path/to/repo/.venv/bin/python
MCP_CLS_STDIO_COMMAND=python3
MCP_CLS_STDIO_ARGS=-m,mcp_servers.cls_stdio
# MCP_MONITOR_STDIO_COMMAND=/path/to/repo/.venv/bin/python
MCP_MONITOR_STDIO_COMMAND=python3
MCP_MONITOR_STDIO_ARGS=-m,mcp_servers.monitor_stdio

# AIOps 数据模式：mock 用于演示，real 只使用真实数据且不会自动回退 mock。
AIOPS_DATA_MODE=real
AIOPS_RESOURCE_CONFIG=./aiops-resources.yml
AIOPS_HTTP_TIMEOUT_SECONDS=20
AIOPS_VERIFY_TLS=true
# 公网暴露 CLS Webhook 时必须配置随机令牌；回调 URL 使用 ?token=该值
AIOPS_WEBHOOK_TOKEN=replace-with-a-long-random-token
# AIOPS_REPORT_DIR=./runtime/aiops_reports

# =============================================================================
# 腾讯云 CLS（写入子进程环境；真 CLS MCP 实现需自行读取这些变量）
# =============================================================================
TENCENTCLOUD_SECRET_ID=your_secret_id_here
TENCENTCLOUD_SECRET_KEY=your_secret_key_here
TENCENTCLOUD_REGION=ap-guangzhou
TENCENTCLOUD_API_BASE_HOST=tencentcloudapi.com

CLS_TOPIC_ID=your_topic_id_here
CLS_MAX_RESULTS=100
# 可选：自定义 CLS 日志上报域名（留空则使用 {TENCENTCLOUD_REGION}.cls.tencentcs.com）
# CLS_UPLOAD_ENDPOINT=ap-guangzhou.cls.tencentcs.com

# =============================================================================
# Prometheus / 腾讯云 TMP（写入监控 MCP 子进程环境）
# 当前仓库内 monitor_server 仍为 mock，不读这些变量；接入真 Prometheus MCP 时使用。
# =============================================================================
# 本机 Prometheus 示例（与 TMP 二选一，不要重复定义 PROMETHEUS_URL）
# PROMETHEUS_URL=http://127.0.0.1:9090
PROMETHEUS_URL=https://prometheus.ap-guangzhou.tencentcloudapi.com
PROMETHEUS_USERNAME=your_appid
PROMETHEUS_PASSWORD=your_token

# Alertmanager API 地址。无 API 告警载荷时，/api/aiops 会主动拉取 firing 告警。
ALERTMANAGER_URL=https://your-alertmanager.example.com
ALERTMANAGER_USERNAME=your_username
ALERTMANAGER_PASSWORD=your_password
